{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.local/schemas/workflow.schema.json",
  "title": "Workflow",
  "type": "object",
  "additionalProperties": false,
  "required": ["workflow_id", "name", "version", "source", "steps", "approval_policy"],
  "properties": {
    "workflow_id": {
      "type": "string",
      "pattern": "^wf_[a-zA-Z0-9_-]{6,64}$"
    },
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "source": {
      "type": "string",
      "enum": ["manual", "learned", "generated"]
    },
    "description": { "type": "string" },
    "preconditions": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step_id", "tool_id", "input", "verify"],
        "properties": {
          "step_id": { "type": "string" },
          "tool_id": { "type": "string" },
          "input": { "type": "object" },
          "on_failure": {
            "type": "string",
            "enum": ["retry", "fallback_tool", "ask_user", "abort"],
            "default": "ask_user"
          },
          "verify": {
            "type": "object",
            "additionalProperties": false,
            "required": ["required", "strategy"],
            "properties": {
              "required": { "type": "boolean" },
              "strategy": { "type": "string", "enum": ["none", "state_readback", "screen_check", "api_check"] }
            }
          }
        }
      }
    },
    "postconditions": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "approval_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["first_n_runs_require_approval"],
      "properties": {
        "first_n_runs_require_approval": { "type": "integer", "minimum": 0 }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "runs": { "type": "integer", "minimum": 0 },
        "success_rate": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
